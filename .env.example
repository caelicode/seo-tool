# Neon PostgreSQL connection string
DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# Admin auth key (set a strong secret for production; leave empty to disable auth in dev)
ADMIN_API_KEY=""

# Google OAuth2 (for Search Console API)
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add redirect URI: https://your-domain.com/api/gsc/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/gsc/callback"

# Anthropic API (default AI provider for Content Optimizer, Keyword Research, etc.)
# Get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# OpenAI API (alternative AI provider)
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# PageSpeed Insights API key (optional, helps avoid anonymous rate limits)
# Create at https://console.cloud.google.com/apis/credentials (API key type)
# Then enable the PageSpeed Insights API in your Google Cloud project
PAGESPEED_API_KEY=""

# Cron job secret (for Vercel Cron or external schedulers)
# Generate a strong random string: openssl rand -hex 32
CRON_SECRET=""
